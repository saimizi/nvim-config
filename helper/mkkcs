#!/usr/bin/env bash

# mkkcs: create or clean cscope database
# Usage:
#   mkkcs [directory]
#   mkkcs clean [directory]

set -e

# --- Parse subcommand ---------------------------------------------------------

SUBCMD=""
TARGET_DIR=""

if [[ "$1" == "clean" ]]; then
    SUBCMD="clean"
    TARGET_DIR="${2:-$(pwd)}"
else
    SUBCMD="create"
    TARGET_DIR="${1:-$(pwd)}"
fi

TARGET_DIR="$(cd "$TARGET_DIR" && pwd)"

# --- Build skip directory list ------------------------------------------------

DEFAULT_SKIP_DIRS=(
    "test"
    "doc"
    "Documentation"
    "script"
    "scripts"
)

USER_SKIP_DIRS=()
if [[ -n "$SKIP_DIRS" ]]; then
    # shellcheck disable=SC2206
    USER_SKIP_DIRS=($SKIP_DIRS)
fi

SKIP_LIST=("${DEFAULT_SKIP_DIRS[@]}" "${USER_SKIP_DIRS[@]}")

# Build find prune expression as an array (no eval!)
PRUNE_EXPR=()
for d in "${SKIP_LIST[@]}"; do
    PRUNE_EXPR+=( -path "./$d" -prune -o )
done

# --- Clean mode ---------------------------------------------------------------

if [[ "$SUBCMD" == "clean" ]]; then
    echo "Cleaning cscope files in: $TARGET_DIR"

    rm -f "$TARGET_DIR/cscope.out" \
          "$TARGET_DIR/cscope.files" \
          "$TARGET_DIR/cscope.in.out" \
          "$TARGET_DIR/cscope.po.out"

    echo "Done."
    exit 0
fi

# --- Create mode --------------------------------------------------------------

echo "Creating cscope database in: $TARGET_DIR"
cd "$TARGET_DIR"

echo "Generating cscope.files..."

# Use array expansion safely
find . \
    "${PRUNE_EXPR[@]}" \
    -type f \( -name "*.c" -o -name "*.h" -o -name "*.cpp" -o -name "*.hpp" -o -name "*.s" -o -name "*.S" \) \
    -print > cscope.files

echo "Building cscope.out..."
cscope -b -q -k

echo "Done."

